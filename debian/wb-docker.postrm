#!/bin/sh

set -eu

helper="/usr/lib/wb-docker/wb-docker-reconcile"

case "${1:-}" in
    remove|purge|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        if [ -x "$helper" ]; then
            "$helper" postrm "$1" "${2:-}"
        fi
        ;;
    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0

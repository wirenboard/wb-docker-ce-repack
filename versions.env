# wb-docker build manifest — the single source of truth for what to build.
#
# A routine Docker update is a PR that bumps the values below. The CI pipeline
# (jenkins-pipeline-lib: buildDockerRepack) sources this file and feeds it to
# repack/repack-docker-ce.sh. A manual run does exactly the same:
#
#     set -a; . ./versions.env; set +a
#     SUITE=trixie ARCH=arm64 bash repack/repack-docker-ce.sh
#
# WB_SUFFIX is the WB-side version of docker-ce ONLY: +wb100 on a fresh upstream
# Docker, +wb101/+wb102… when our injected code (overlay / postinst snippet)
# changes on top of the same upstream; reset to +wb100 when DOCKER_CE_VERSION is
# bumped.

DOCKER_CE_VERSION=29.5.2
CONTAINERD_VERSION=2.2.4
COMPOSE_VERSION=5.1.4
WB_SUFFIX=+wb100

# Build matrix (space-separated). Add a suite here when WB starts shipping on a
# new Debian base.
SUITES="trixie"
ARCHES="armhf arm64"
